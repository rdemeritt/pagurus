# ============================================================
# Pagurus — Self-hosted MCP Server
# Copy to .env and fill in values. REQUIRED vars must be set.
# ============================================================

# ---- Server ------------------------------------------------

# Hostname/IP to bind to. Default: 127.0.0.1 (loopback).
# Set to 0.0.0.0 only if you know what you're doing (e.g. direct Docker expose).
PAGURUS_BIND_HOST=127.0.0.1

# Port to listen on. Default: 8080.
PAGURUS_BIND_PORT=8080

# Public URL of this Pagurus instance (used for DNS-rebinding defense).
# REQUIRED for production. Example: https://pagurus.yourdomain.com
PAGURUS_EXTERNAL_URL=https://pagurus.yourdomain.com  # REQUIRED

# ---- Authentication ----------------------------------------
# WARNING: Keep this file private (chmod 600 .env).
# These keys are stored in plaintext in this file.
# Anyone with host shell access can read them.

# Comma-separated API keys. Generate with: pnpm pagurus keygen
# REQUIRED — server refuses to start if empty.
PAGURUS_API_KEYS=pag_live_REPLACE_ME  # REQUIRED

# ---- File System Tool (fs.*) --------------------------------

# Absolute path on the host to expose as the sandboxed workspace root.
# REQUIRED. Must exist and be a directory.
PAGURUS_FS_ROOT=/home/youruser/workspace  # REQUIRED

# Allow fs.write tool (write/overwrite files). Default: true.
# Set to false for read-only deployments.
PAGURUS_FS_WRITE=true

# Comma-separated minimatch glob patterns to deny access (relative to FS_ROOT).
# Example: .env,.secrets/**,**/*.key
PAGURUS_FS_DENYLIST=.env,.env.*,**/*.key,**/*.pem,**/*.p12

# Maximum file size for reads/writes in bytes. Default: 1048576 (1 MiB). Max: 104857600 (100 MiB).
PAGURUS_FS_MAX_READ_BYTES=1048576

# ---- HTTP Fetch Tool (http.fetch) ---------------------------

# Comma-separated hostname allow-list. Empty = deny all.
# Use * to allow all hosts (open egress — only for trusted, private networks).
# Wildcards: *.example.com matches sub.example.com but NOT example.com.
# Example: api.github.com,*.api.example.com
PAGURUS_HTTP_ALLOWLIST=

# WARNING: Setting this to true disables ALL SSRF protection (private IP blocking).
# Only use on isolated private networks. NEVER in production.
PAGURUS_HTTP_ALLOW_PRIVATE=false

# ---- Shell Exec Tool (shell.exec) ---------------------------
# WARNING: shell.exec is the highest-risk feature. Read the security docs before enabling.

# Enable the shell.exec tool. Default: false (tool is hidden from tools/list when disabled).
PAGURUS_SHELL_ENABLED=false

# Comma-separated list of allowed command basenames.
# These commands must exist in /usr/local/bin, /usr/bin, or /bin.
# Shells, interpreters, and exec wrappers are ALWAYS blocked regardless of this list.
# Example: git,ls,cat,grep,rg,jq
PAGURUS_SHELL_ALLOWLIST=

# ---- HermitHost (docker-compose.hermithost.yml) -------------

# Your domain for Traefik routing. Example: pagurus.yourdomain.com
PAGURUS_DOMAIN=pagurus.yourdomain.com

# Host path to mount as /workspace inside the container.
# This is the same directory as PAGURUS_FS_ROOT from the host perspective.
HOST_WORKSPACE=/home/youruser/workspace
